{
  "name": "HarmonyRNBase",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "xinstall": "rm -rf node_modules; yarn install",

    "dev": "npx react-native link-harmony && react-native bundle-harmony --dev",
    "hdc": "hdc rport tcp:8081 tcp:8081",
    "adb": "adb reverse tcp:8081 tcp:8081",
    "ohpm": "cd harmony/entry/ && ohpm install",
    "cleanAndroid": "cd android && ./gradlew clean && rm -rf .gradle && cd ..",
    "postinstall": "patch-package",
    "i": "yarn install --frozen-lockfile"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
