    "@react-navigation/material-top-tabs": "7.2.0",
    "@react-navigation/native": "7.2.0",
    "@react-navigation/native-stack": "7.2.0",
    "@react-navigation/stack": "7.2.0",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.5",
    "crypto-js": "^4.2.0",
    "decimal.js": "10.4.3",
